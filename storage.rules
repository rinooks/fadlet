rules_version = '2';
service firebase.storage {
  match /b/{bucket}/o {
    match /workspaces/{wsId}/boards/{boardId}/{fileType}/{fileId} {
      // 보드 파일은 누구나 읽기 가능 (익명 참여자 포함)
      allow read: if true;

      // 이미지: 인증된 사용자, 10MB 이하, 이미지 타입만. SVG는 스크립트 삽입 가능해 차단(저장형 XSS 방지).
      allow create: if request.auth != null
        && fileType == 'images'
        && request.resource.size < 10 * 1024 * 1024
        && request.resource.contentType.matches('image/.*')
        && !request.resource.contentType.matches('image/svg.*');

      // 첨부파일: 인증된 사용자, 20MB 이하. HTML/SVG/XHTML 등 인라인 실행 가능한 타입은 차단(저장형 XSS·피싱 방지).
      allow create: if request.auth != null
        && fileType == 'files'
        && request.resource.size < 20 * 1024 * 1024
        && !request.resource.contentType.matches('text/html.*')
        && !request.resource.contentType.matches('image/svg.*')
        && !request.resource.contentType.matches('application/xhtml.*');

      // 삭제: 슈퍼관리자만 (클라이언트는 파일을 삭제하지 않음 — 임의 삭제 차단)
      allow delete: if request.auth != null
        && request.auth.token.email == 'rinooks@gmail.com';
    }
  }
}
