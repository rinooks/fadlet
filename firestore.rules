rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {

    function isAuthenticated() {
      return request.auth != null;
    }

    function isOwner(wsId, boardId) {
      return get(/databases/$(database)/documents/workspaces/$(wsId)/boards/$(boardId)).data.ownerId == request.auth.uid;
    }

    function isWorkspaceOwner(wsId) {
      return exists(/databases/$(database)/documents/workspaces/$(wsId)) &&
        get(/databases/$(database)/documents/workspaces/$(wsId)).data.ownerUid == request.auth.uid;
    }

    function isWorkspaceMember(wsId) {
      return exists(/databases/$(database)/documents/workspaces/$(wsId)/members/$(request.auth.uid));
    }

    function isWorkspaceMemberAdmin(wsId) {
      return isAllowedOperator()
        && exists(/databases/$(database)/documents/workspaces/$(wsId)/members/$(request.auth.uid))
        && get(/databases/$(database)/documents/workspaces/$(wsId)/members/$(request.auth.uid)).data.role == 'admin';
    }

    // 슈퍼관리자: 하드코딩된 이메일
    function isSuperAdmin() {
      return request.auth != null
        && request.auth.token.email in ['rinooks@gmail.com'];
    }

    // 운영자(워크스페이스/보드 생성) 권한: operators/{uid}.allowed == true 일 때만 허용
    function isAllowedOperator() {
      return request.auth != null
        && exists(/databases/$(database)/documents/operators/$(request.auth.uid))
        && get(/databases/$(database)/documents/operators/$(request.auth.uid)).data.allowed == true;
    }

    // 앱 전역 설정 (Gemini API 키 등) — super-admin이 쓰고, 승인된 퍼실리테이터가 읽음.
    match /settings/{docId} {
      allow read: if isAllowedOperator() || isSuperAdmin();
      allow write: if isSuperAdmin();
    }

    // 업데이트 노트 — 게시된 항목은 누구나 읽기, 슈퍼 관리자가 작성/수정/삭제.
    match /updateNotes/{noteId} {
      allow read, list: if true;
      allow create, update, delete: if isSuperAdmin();
    }

    // 인앱 피드백 — 인증된 누구나 작성, 슈퍼 관리자만 읽기/관리.
    match /feedback/{feedbackId} {
      allow read, list, delete: if isSuperAdmin();
      allow create: if isAuthenticated()
        && request.resource.data.uid == request.auth.uid;
      allow update: if isSuperAdmin();
    }

    // users 컬렉션: 본인 read/write, 슈퍼관리자가 전체 read
    match /users/{uid} {
      allow read: if isAuthenticated() && (request.auth.uid == uid || isSuperAdmin());
      allow list: if isSuperAdmin();
      allow create, update: if isAuthenticated()
        && request.auth.uid == uid
        && request.resource.data.uid == uid;
      allow delete: if isSuperAdmin();
    }

    // operators 컬렉션: 본인은 문서 read 가능, super가 전체 read/write
    match /operators/{uid} {
      allow read: if isAuthenticated() && (request.auth.uid == uid || isSuperAdmin());
      allow list: if isSuperAdmin();
      // 첫 로그인 시 본인이 자기 문서를 생성. 자동 승인이므로 allowed는 true 허용.
      // isSuperAdmin은 슈퍼관리자만 true 설정 가능.
      allow create: if isAuthenticated()
        && request.auth.uid == uid
        && request.resource.data.uid == uid
        && (request.resource.data.isSuperAdmin == false || isSuperAdmin());
      // 본인은 메타(displayName/email/lastLoginAt)만 갱신, allowed/isSuperAdmin은 슈퍼만
      allow update: if isAuthenticated()
        && (
          isSuperAdmin()
          || (request.auth.uid == uid
              && request.resource.data.allowed == resource.data.allowed
              && request.resource.data.isSuperAdmin == resource.data.isSuperAdmin)
        );
      allow delete: if isSuperAdmin();
    }

    // collectionGroup('members') 쿼리 — 본인 멤버십만 조회. 슈퍼관리자는 전체.
    // (사용처: lib/hooks/use-workspaces.ts → where('uid','==',본인uid) / app/admin/page.tsx → super only)
    match /{path=**}/members/{memberUid} {
      allow read: if isAuthenticated() && (request.auth.uid == memberUid || isSuperAdmin());
    }

    match /workspaces/{wsId} {
      allow read: if true;
      allow create: if isAllowedOperator()
        && request.resource.data.ownerUid == request.auth.uid;
      allow update, delete: if isSuperAdmin()
        || (isAllowedOperator() && resource.data.ownerUid == request.auth.uid);

      match /members/{memberUid} {
        allow read: if isAuthenticated();
        allow create: if isAllowedOperator()
          && request.auth.uid == memberUid
          && request.resource.data.uid == memberUid;
        allow update: if isAllowedOperator()
          && (request.auth.uid == memberUid || isWorkspaceOwner(wsId));
        allow delete: if isAllowedOperator()
          && (request.auth.uid == memberUid || isWorkspaceOwner(wsId));
      }

      match /boards/{boardId} {
        allow read: if true;
        // 보드 생성: 승인된 운영자(워크스페이스 멤버) 또는 데모 보드(누구나)
        allow create: if (isAllowedOperator()
            && request.resource.data.ownerId == request.auth.uid
            && request.resource.data.workspaceId is string
            && request.resource.data.workspaceId != 'default'
            && isWorkspaceMember(request.resource.data.workspaceId))
          || (isAuthenticated()
            && request.resource.data.ownerId == request.auth.uid
            && request.resource.data.workspaceId == 'demo'
            && request.resource.data.isDemo == true);
        // 업데이트 권한: 슈퍼관리자, 소유자, 또는 현재 워크스페이스 admin.
        // workspaceId가 변경되는 경우 새 워크스페이스의 멤버여야 하고 'default'/'demo'는 금지.
        allow update: if isSuperAdmin()
          || (
            (
              (isAllowedOperator() && resource.data.ownerId == request.auth.uid)
              || isWorkspaceMemberAdmin(resource.data.workspaceId)
            )
            && (
              request.resource.data.workspaceId == resource.data.workspaceId
              || (
                request.resource.data.workspaceId is string
                && request.resource.data.workspaceId != 'default'
                && request.resource.data.workspaceId != 'demo'
                && isWorkspaceMember(request.resource.data.workspaceId)
              )
            )
          );
        allow delete: if isSuperAdmin()
          || (isAllowedOperator() && resource.data.ownerId == request.auth.uid);

        match /posts/{postId} {
          allow read: if true;
          allow create: if isAuthenticated()
            && request.resource.data.authorId == request.auth.uid;
          allow update, delete: if isAuthenticated()
            && (resource.data.authorId == request.auth.uid || isOwner(wsId, boardId));

          // 포스트 이모지 반응 — 1인 1반응 (문서 id == auth.uid)
          match /reactions/{userId} {
            allow read: if true;
            allow create, update: if isAuthenticated()
              && request.auth.uid == userId
              && request.resource.data.userId == userId;
            allow delete: if isAuthenticated()
              && (request.auth.uid == userId || isOwner(wsId, boardId));
          }

          // 포스트 댓글 — 본인 작성/삭제, 운영자 삭제
          match /comments/{commentId} {
            allow read: if true;
            allow create: if isAuthenticated()
              && request.resource.data.authorId == request.auth.uid;
            allow update, delete: if isAuthenticated()
              && (resource.data.authorId == request.auth.uid || isOwner(wsId, boardId));
          }
        }

        match /messages/{messageId} {
          allow read: if true;
          allow create: if isAuthenticated()
            && request.resource.data.authorId == request.auth.uid;
          allow update: if isAuthenticated()
            && (
              resource.data.authorId == request.auth.uid
              || isOwner(wsId, boardId)
              || request.resource.data.diff(resource.data).affectedKeys().hasOnly(['reactions'])
            );
          allow delete: if isAuthenticated()
            && (resource.data.authorId == request.auth.uid || isOwner(wsId, boardId));
        }

        match /participants/{userId} {
          allow read: if true;
          allow write: if isAuthenticated()
            && request.auth.uid == userId;
        }

        match /reports/{reportId} {
          allow read: if isAuthenticated() && isOwner(wsId, boardId);
          allow create: if isAuthenticated()
            && request.resource.data.reporterId == request.auth.uid
            && request.resource.data.status == 'open';
          allow update: if isAuthenticated() && isOwner(wsId, boardId);
          allow delete: if isAuthenticated() && isOwner(wsId, boardId);
        }

        // 라이브 폴 응답 — 1인 1응답 (userId == auth.uid)
        match /pollResponses/{responseId} {
          allow read: if true;
          allow create, update: if isAuthenticated()
            && request.resource.data.userId == request.auth.uid;
          allow delete: if isAuthenticated()
            && (resource.data.userId == request.auth.uid || isOwner(wsId, boardId));
        }

        // 워드클라우드 입력 — 본인 작성/삭제, 운영자 삭제
        match /wordcloudEntries/{entryId} {
          allow read: if true;
          allow create: if isAuthenticated()
            && request.resource.data.userId == request.auth.uid;
          allow delete: if isAuthenticated()
            && (resource.data.userId == request.auth.uid || isOwner(wsId, boardId));
        }

        // 라이브 Q&A 질문 — 본인 작성, 모두 좋아요, 운영자 답변/완료
        match /qnaQuestions/{questionId} {
          allow read: if true;
          allow create: if isAuthenticated()
            && request.resource.data.authorId == request.auth.uid
            && request.resource.data.upvotes is list
            && request.resource.data.upvotes.size() == 0
            && request.resource.data.answered == false;
          // 좋아요만 변경(upvotes) 또는 운영자가 답변/완료 처리
          allow update: if isAuthenticated()
            && (
              request.resource.data.diff(resource.data).affectedKeys().hasOnly(['upvotes'])
              || isOwner(wsId, boardId)
            );
          allow delete: if isAuthenticated()
            && (resource.data.authorId == request.auth.uid || isOwner(wsId, boardId));
        }

        // 액티비티 런타임 상태(공개/마감) — 운영자만 쓰기
        match /activityStates/{stageId} {
          allow read: if true;
          allow write: if isAuthenticated() && isOwner(wsId, boardId);
        }
      }
    }
  }
}
