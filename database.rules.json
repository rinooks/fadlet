{
  "rules": {
    "presence": {
      "$boardId": {
        ".read": true,
        "$sessionId": {
          ".write": "auth != null"
        }
      }
    },
    "typing": {
      "$boardId": {
        ".read": true,
        "$uid": {
          ".write": "auth != null && auth.uid === $uid"
        }
      }
    }
  }
}
